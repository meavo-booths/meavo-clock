# Shared Neon Postgres (same instance as gateway, hols, rp, etc.)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# NextAuth (same pattern as other Meavo apps)
AUTH_SECRET=generate-a-long-random-string
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# Kiosk device API key (ESP32 sends X-Device-Key header)
DEVICE_API_KEY=generate-a-strong-random-key

# Tool card ID from gateway (default matches seed-clock-tool)
CLOCK_TOOL_CARD_ID=seed-clock-tool

# Vercel cron protection
CRON_SECRET=generate-a-random-cron-secret

# Public URL
NEXT_PUBLIC_APP_URL=https://clock.meavo.app
