PORT=3001
DEVICE_API_KEY=meavo-kiosk-dev-key-change-in-production
DATABASE_PATH=./data/meavo.db

# Google SSO (create OAuth 2.0 Web client at console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
SESSION_SECRET=change-to-a-long-random-string

# Comma-separated admin emails allowed to sign in
ALLOWED_ADMIN_EMAILS=you@yourcompany.com

# --- Local development ---
WEB_ORIGIN=http://localhost:5173
# PUBLIC_URL=http://localhost:3001

# --- Production (clock.meavo.app) ---
# NODE_ENV=production
# WEB_ORIGIN=https://clock.meavo.app
# PUBLIC_URL=https://clock.meavo.app
# TRUST_PROXY=1
# SERVE_STATIC=1
