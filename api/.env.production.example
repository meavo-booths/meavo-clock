# Production environment — copy to api/.env on the server

NODE_ENV=production
PORT=3001
DEVICE_API_KEY=generate-a-strong-random-key
DATABASE_PATH=./data/meavo.db

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
SESSION_SECRET=generate-a-long-random-string

ALLOWED_ADMIN_EMAILS=you@meavo.app

WEB_ORIGIN=https://clock.meavo.app
PUBLIC_URL=https://clock.meavo.app
TRUST_PROXY=1
SERVE_STATIC=1
